{
  "schemaVersion": 1,
  "id": "whcraft",
  "version": "${version}",
  "name": "WhCraft",
  "description": "This is a Warhammer 40K mod, featuring the implementation of Warhammer 40K content in Minecraft alongside the author's own vision for the setting. ",
  "authors": ["42","ShuShu"],
  "contact": {},
  "license": "GPL-3.0",
  "icon": "assets/whcraft/icon.png",
  "environment": "*",
  "entrypoints": {
    "fabric-datagen": [
      "org.whcraft.whcraft.client.WhcraftDataGenerator"
    ],
    "client": [
      "org.whcraft.whcraft.client.WhcraftClient"
    ],
    "main": [
      "org.whcraft.whcraft.Whcraft"
    ],
    "cardinal-components": [
      "org.whcraft.whcraft.WhcraftComponents"
    ]
  },
  "mixins": [
    "whcraft.mixins.json",
    {
      "config": "whcraft.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}",
    "cardinal-components-base": ">=${cca_version}",
    "cardinal-components-entity": ">=${cca_version}"
  },
  "custom": {
    "cardinal-components": [
      "whcraft:implants"
    ]
  }
}

